{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "src/pages/api/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/src/pages/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
